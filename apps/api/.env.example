# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lor_mentor?schema=public"

# ── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── App ───────────────────────────────────────────────────────
NODE_ENV="development"
PORT="4000"
CORS_ORIGIN="http://localhost:3000"
# Public base URLs used to build Chapa callback (API) and return (web) URLs.
# Locally these match PORT/CORS_ORIGIN; in production set them to your real
# HTTPS domains (the webhook must be reachable by Chapa from the internet).
API_PUBLIC_URL="http://localhost:4000"
WEB_PUBLIC_URL="http://localhost:3000"

# ── AI (Google Gemini) ────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"

# ── Chapa payment gateway ─────────────────────────────────────
# Get keys from https://dashboard.chapa.co (Settings → API). Use the TEST
# secret key (CHASECK_TEST-...) during development. CHAPA_WEBHOOK_SECRET is the
# "Secret hash" you set on the Webhooks page — it signs every webhook payload.
CHAPA_SECRET_KEY="CHASECK_TEST-xxxxxxxxxxxxxxxx"
CHAPA_WEBHOOK_SECRET="set-this-to-match-the-chapa-dashboard-webhook-secret"
CHAPA_BASE_URL="https://api.chapa.co/v1"

# Optional branding shown on the generated PDF receipt
COLLEGE_NAME="Lorcan Medical College"
APP_NAME="Lor Mentor"

# ── Super admin bootstrap (break-glass) ───────────────────────
# Created idempotently by `npm run db:seed`. The seed never overwrites an
# existing super admin's password, so set these BEFORE the first seed and
# change the password after first login. If unset, documented defaults are
# used (superadmin@lorcan.edu.et / ChangeMe!2026) and a warning is printed.
SUPER_ADMIN_EMAIL="superadmin@lorcan.edu.et"
SUPER_ADMIN_PASSWORD="ChangeMe!2026"
SUPER_ADMIN_NAME="Super Admin"
