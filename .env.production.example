# ============================================================================
# Lor Mentor — PRODUCTION environment (docker-compose.prod.yml)
# ----------------------------------------------------------------------------
# Copy to `.env.production` on the VPS and fill in real values. NEVER commit the
# filled file (.gitignore already excludes .env.production). Used both as the
# compose --env-file (for ${VAR} substitution) and each service's env_file.
# ============================================================================

# ── Core ────────────────────────────────────────────────────────────
NODE_ENV=production

# Public URLs — must be the real HTTPS origins (no localhost). Chapa callbacks,
# email links and CORS are built from these.
WEB_PUBLIC_URL=https://lormentor.com
API_PUBLIC_URL=https://api.lormentor.com
APP_URL=https://lormentor.com
API_URL=https://api.lormentor.com
COLLEGE_NAME=Lorcan Medical College
APP_NAME=Lor Mentor

# CORS: the exact frontend origin(s) allowed to call the API (comma-separated).
CORS_ORIGIN=https://lormentor.com

# Browser-facing API URL, inlined into the web bundle at build time.
NEXT_PUBLIC_API_URL=https://api.lormentor.com

# ── PostgreSQL (internal to the compose network) ────────────────────
POSTGRES_USER=lor
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=lor_mentor
# Host is the compose service name `postgres`, not localhost.
DATABASE_URL=postgresql://lor:CHANGE_ME_strong_db_password@postgres:5432/lor_mentor

# ── JWT (generate with: openssl rand -hex 48) ───────────────────────
# Must be >= 32 chars, high-entropy, and DIFFERENT from each other.
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_hex_48
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_openssl_rand_hex_48
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Email (transactional SMTP — e.g. Resend / SendGrid / SES / Mailgun) ──
# Verify your sending domain (SPF + DKIM) for inbox delivery.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=CHANGE_ME_smtp_api_key
SMTP_FROM=Lor Mentor <no-reply@lormentor.com>

# ── Gemini AI ───────────────────────────────────────────────────────
GEMINI_API_KEY=CHANGE_ME_gemini_api_key

# ── Redis (internal; host is the service name) ──────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Chapa online payments (OPTIONAL — leave ALL blank to launch without it) ──
# The bank-transfer + manual-review flow is the primary payment path. When you
# get LIVE keys, set BOTH together (env validation enforces all-or-nothing).
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=

# ── Bank-receipt auto-verification (receipt-verifier service) ───────
# URL is set by compose to http://verifier:8000 — leave as-is here.
RECEIPT_VERIFIER_URL=http://verifier:8000
# Shared secret between API and the Python verifier (openssl rand -hex 24).
RECEIPT_VERIFIER_TOKEN=CHANGE_ME_shared_verifier_token
# REQUIRED when the verifier is enabled: your real receiving account numbers.
# Auto-approval only fires when a receipt is paid INTO one of these.
COMPANY_BANK_ACCOUNTS=1000123456789,0900112233
