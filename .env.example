# ─── App ────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
COLLEGE_NAME="Lorcan Medical College"
APP_NAME="Lor Mentor"

# ─── Database ───────────────────────────────────
# Replace YOUR_PASSWORD with the password you set during PostgreSQL install
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/lower_mentor"

# ─── JWT Tokens ─────────────────────────────────
# Generate random secrets — never share these
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Lor Mentor <your_email@gmail.com>"

# ─── Gemini AI ──────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Redis / BullMQ AI Jobs ─────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Sentry Error Tracking ──────────────────────
# Optional. Leave blank to disable. Get your DSN from sentry.io.
SENTRY_DSN=

# ─── Chapa Sandbox Payments ─────────────────────
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_SECRET_KEY=CHASECK_TEST_xxx
CHAPA_WEBHOOK_SECRET=your_chapa_webhook_secret

# ─── Bank-receipt auto-verification (receipt-verifier service) ──
# Base URL of the Python receipt-verifier service (see services/receipt-verifier).
# Leave blank to disable automated bank-transfer verification entirely.
RECEIPT_VERIFIER_URL=http://localhost:8000
# Must match VERIFIER_SHARED_TOKEN in the receipt-verifier service .env.
RECEIPT_VERIFIER_TOKEN=
# Comma-separated list of OUR bank account numbers that receipts must be paid
# INTO for auto-approval. Required whenever RECEIPT_VERIFIER_URL is set.
# Example: 1000123456789,0900112233
COMPANY_BANK_ACCOUNTS=

# ─── Frontend ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
